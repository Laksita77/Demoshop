<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"><Styles><Style ss:ID="Default" ss:Name="Normal"><Alignment ss:Vertical="Top" ss:WrapText="1"/><Font ss:FontName="Calibri" ss:Size="11"/></Style><Style ss:ID="H"><Font ss:Bold="1" ss:Color="#FFFFFF"/><Interior ss:Color="#1F4E78" ss:Pattern="Solid"/></Style><Style ss:ID="F"><Interior ss:Color="#FCE4D6" ss:Pattern="Solid"/></Style></Styles><Worksheet ss:Name="Scenario_TestData"><Table>
<Row ss:StyleID="H"><Cell><Data ss:Type="String">ScenarioID</Data></Cell><Cell><Data ss:Type="String">ScenarioName</Data></Cell><Cell><Data ss:Type="String">TestDataID</Data></Cell><Cell><Data ss:Type="String">URL</Data></Cell><Cell><Data ss:Type="String">Username</Data></Cell><Cell><Data ss:Type="String">Password</Data></Cell><Cell><Data ss:Type="String">ProductName</Data></Cell><Cell><Data ss:Type="String">DataType</Data></Cell><Cell><Data ss:Type="String">ExpectedResult</Data></Cell><Cell><Data ss:Type="String">Notes</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-REGISTER-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop customer registration</Data></Cell><Cell><Data ss:Type="String">TD-REGISTER-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell><Data ss:Type="String">codex.qa.20260716.124100@example.com</Data></Cell><Cell><Data ss:Type="String">Demo@12345</Data></Cell><Cell/><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">Registration should succeed and a confirmation message should be displayed.</Data></Cell><Cell><Data ss:Type="String">Create customer as Codex QA Tester; use Username as Email. Use a fresh unique email when rerunning.</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-LOGIN-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop login functionality</Data></Cell><Cell><Data ss:Type="String">TD-LOGIN-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell><Data ss:Type="String">codex.qa.20260716.124100@example.com</Data></Cell><Cell><Data ss:Type="String">Demo@12345</Data></Cell><Cell/><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">Login should succeed and the customer email should appear in the header.</Data></Cell><Cell><Data ss:Type="String">Positive login; run after TD-REGISTER-001.</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-LOGIN-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop login functionality</Data></Cell><Cell><Data ss:Type="String">TD-LOGIN-002</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell><Data ss:Type="String">invalid.user@example.com</Data></Cell><Cell><Data ss:Type="String">WrongPass123</Data></Cell><Cell/><Cell><Data ss:Type="String">Invalid</Data></Cell><Cell><Data ss:Type="String">Login should fail and an unsuccessful-login error message should be displayed.</Data></Cell><Cell><Data ss:Type="String">Negative login validation</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-SEARCH-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop product search</Data></Cell><Cell><Data ss:Type="String">TD-SEARCH-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Fiction</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">Search results should include the product named Fiction.</Data></Cell><Cell><Data ss:Type="String">Search for an existing product</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-SEARCH-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop product search</Data></Cell><Cell><Data ss:Type="String">TD-SEARCH-002</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Product That Does Not Exist 98765</Data></Cell><Cell><Data ss:Type="String">Invalid</Data></Cell><Cell><Data ss:Type="String">The search page should report that no products were found.</Data></Cell><Cell><Data ss:Type="String">Negative search validation</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-CART-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop add-to-cart functionality</Data></Cell><Cell><Data ss:Type="String">TD-CART-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Fiction</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">The selected product should be added and the shopping-cart quantity should become 1.</Data></Cell><Cell><Data ss:Type="String">Add a book to cart</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-CART-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop add-to-cart functionality</Data></Cell><Cell><Data ss:Type="String">TD-CART-002</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">14.1-inch Laptop</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">The selected product should be visible on the shopping-cart page.</Data></Cell><Cell><Data ss:Type="String">Verify product name in cart</Data></Cell></Row>
<Row ss:StyleID="F"><Cell><Data ss:Type="String">TS-CART-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop add-to-cart functionality</Data></Cell><Cell><Data ss:Type="String">TD-CART-003</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Fiction XYZ</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">The named product should be found and added to the shopping cart.</Data></Cell><Cell><Data ss:Type="String">Deliberate failure to validate screenshot, classification, and Jira workflow.</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-WISHLIST-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop wishlist functionality</Data></Cell><Cell><Data ss:Type="String">TD-WISHLIST-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell><Data ss:Type="String">codex.qa.20260716.124100@example.com</Data></Cell><Cell><Data ss:Type="String">Demo@12345</Data></Cell><Cell><Data ss:Type="String">Computing and Internet</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">The selected product should be added to and displayed in the wishlist.</Data></Cell><Cell><Data ss:Type="String">Login if required and verify wishlist quantity</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-CART-REMOVE-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop remove-from-cart functionality</Data></Cell><Cell><Data ss:Type="String">TD-CART-REMOVE-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Fiction</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">After removing the product and updating the cart, the cart should be empty.</Data></Cell><Cell><Data ss:Type="String">Add Fiction first and then remove it</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-CHECKOUT-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop end-to-end checkout</Data></Cell><Cell><Data ss:Type="String">TD-CHECKOUT-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell><Data ss:Type="String">codex.qa.20260716.124100@example.com</Data></Cell><Cell><Data ss:Type="String">Demo@12345</Data></Cell><Cell><Data ss:Type="String">Fiction</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">The product should be added and checkout should accept customer and billing information.</Data></Cell><Cell><Data ss:Type="String">Billing: Codex QA Tester, India, 1 Test Street, Bengaluru, 560001, 9999999999.</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-CHECKOUT-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop end-to-end checkout</Data></Cell><Cell><Data ss:Type="String">TD-CHECKOUT-002</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell><Data ss:Type="String">codex.qa.20260716.124100@example.com</Data></Cell><Cell><Data ss:Type="String">Demo@12345</Data></Cell><Cell><Data ss:Type="String">Computing and Internet</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">The second product should be added and the order should complete with a success confirmation.</Data></Cell><Cell><Data ss:Type="String">Continue TD-CHECKOUT-001; use ground shipping and a supported non-destructive payment option.</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-PRICE-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop cart price calculation</Data></Cell><Cell><Data ss:Type="String">TD-PRICE-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Fiction</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">Unit price multiplied by quantity should equal the displayed subtotal.</Data></Cell><Cell><Data ss:Type="String">Single-product price verification</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-PRICE-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop cart price calculation</Data></Cell><Cell><Data ss:Type="String">TD-PRICE-002</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Computing and Internet</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">The cart total should equal the sum of displayed line-item subtotals.</Data></Cell><Cell><Data ss:Type="String">Add Fiction and Computing and Internet, then calculate total manually.</Data></Cell></Row>
<Row><Cell><Data ss:Type="String">TS-SORT-001</Data></Cell><Cell><Data ss:Type="String">Validate Demo Web Shop product sorting</Data></Cell><Cell><Data ss:Type="String">TD-SORT-001</Data></Cell><Cell><Data ss:Type="String">https://demowebshop.tricentis.com/books</Data></Cell><Cell/><Cell/><Cell><Data ss:Type="String">Books</Data></Cell><Cell><Data ss:Type="String">Valid</Data></Cell><Cell><Data ss:Type="String">Sorting books by price low to high should display prices in ascending order.</Data></Cell><Cell><Data ss:Type="String">Category sorting validation</Data></Cell></Row>
